.env
.env.*

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
.venv_local/
.pytest_cache/
*.egg-info/
dist/
build/

# Node (root-level tools if any)
node_modules/

# IDE / OS
.idea/
.vscode/
.DS_Store

# Local data (SQLite uploads; keep tree via README or empty .gitkeep if needed)
data/*.db
data/*.db-journal

# Generated media (regenerate on server)
static/generated/
static/uploads/

# Runtime logs & pid files (see scripts/start-all.sh)
logs/*
!logs/.gitkeep
run/*
!run/.gitkeep
